{
  "kind": "singleType",
  "collectionName": "smtp_settings",
  "info": {
    "singularName": "smtp-setting",
    "pluralName": "smtp-settings",
    "displayName": "SMTP Settings",
    "description": "Outgoing email (SMTP) credentials for dealer-submission notifications, plus the Google reCAPTCHA v3 keys used to protect the dealer onboarding form. Managed here in the admin instead of .env. The password and reCAPTCHA secret key are stored as plain text (not encrypted) by design; the secret key is marked private so it is never returned by the API."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "host": {
      "type": "string",
      "required": true,
      "default": "smtp.office365.com"
    },
    "port": {
      "type": "integer",
      "required": true,
      "default": 587
    },
    "secure": {
      "type": "boolean",
      "default": false
    },
    "username": {
      "type": "string"
    },
    "password": {
      "type": "string"
    },
    "fromEmail": {
      "type": "string",
      "default": "noreply7@caravea.au"
    },
    "fromName": {
      "type": "string",
      "default": "Escape The Noise"
    },
    "notifyEmail": {
      "type": "string",
      "default": "noreply7@caravea.au"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "recaptchaEnabled": {
      "type": "boolean",
      "default": false
    },
    "recaptchaSiteKey": {
      "type": "string"
    },
    "recaptchaSecretKey": {
      "type": "string",
      "private": true
    }
  }
}
