{
  "name": "project-baseplate-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run develop --workspace=backend",
    "dev:backend:clean": "npm run dev:clean --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "build:synergy": "npm run build:synergy --workspace=frontend",
    "verify:synergy": "npm run verify:synergy --workspace=frontend",
    "archive:synergy": "npm run archive:synergy --workspace=frontend",
    "release:synergy": "npm run build:synergy && npm run verify:synergy && npm run archive:synergy",
    "build:backend": "npm run build --workspace=backend",
    "clean:backend": "npm run clean --workspace=backend",
    "start": "node app.js",
    "start:frontend": "npm run start --workspace=frontend",
    "lint": "npm run lint --workspace=frontend"
  },
  "devDependencies": {
    "claude-brain": "github:caravea-au/claude-brain#v0.1.4"
  }
}
